# ================================================
# Synapse Frontend – Environment Variables
# ================================================
# Salin file ini menjadi .env.local dan isi nilai.
# Lihat DEVELOPER_SETUP.md untuk panduan lengkap.
# ================================================

# --- Supabase (Frontend) ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# --- Backend API ---
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"

# --- Midtrans (Frontend – hanya client key) ---
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="SB-Mid-client-your-client-key"
NEXT_PUBLIC_MIDTRANS_SNAP_URL="https://app.sandbox.midtrans.com/snap/snap.js"
